{
  "name": "@mathnotes/mobile-ink",
  "version": "0.1.0",
  "description": "Production-grade React Native ink engine with native Skia/Metal drawing and continuous canvas primitives.",
  "license": "Apache-2.0",
  "author": "BuilderPro LLC",
  "private": false,
  "main": "./lib/commonjs/index.js",
  "react-native": "./src/index.ts",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "files": [
    "lib",
    "src/ContinuousEnginePool.tsx",
    "src/InfiniteInkCanvas.tsx",
    "src/NativeInkCanvas.tsx",
    "src/NativeInkPageBackground.tsx",
    "src/ZoomableInkViewport.tsx",
    "src/index.ts",
    "src/payload.ts",
    "src/types.ts",
    "src/utils",
    "ios",
    "cpp",
    "docs/*.md",
    "MathNotesMobileInk.podspec",
    "react-native.config.js",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:native:smoke": "clang++ -std=c++20 scripts/drawing_serialization_smoke.cpp cpp/DrawingSerialization.cpp -I cpp -I node_modules/@shopify/react-native-skia/cpp/skia -I node_modules/@shopify/react-native-skia/cpp/skia/modules/pathops/include node_modules/@shopify/react-native-skia/libs/apple/libskia.xcframework/macos-arm64_x86_64/libskia.a node_modules/@shopify/react-native-skia/libs/apple/libpathops.xcframework/macos-arm64_x86_64/libpathops.a -framework ApplicationServices -framework CoreFoundation -framework CoreGraphics -framework CoreText -framework Foundation -framework QuartzCore -o /tmp/mobile_ink_drawing_serialization_smoke && /tmp/mobile_ink_drawing_serialization_smoke",
    "test:example:typecheck": "npm --prefix example run typecheck",
    "test:example:export:ios": "npm --prefix example run export:ios",
    "pack:dry-run": "npm pack --dry-run",
    "validate": "npm run typecheck && npm run test && npm run test:native:smoke && npm run build && npm run pack:dry-run && npm run test:example:typecheck && npm run test:example:export:ios",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=2.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-gesture-handler": ">=2.28.0",
    "react-native-reanimated": ">=4.1.0",
    "react-native-worklets": ">=0.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/babel-preset": "0.81.5",
    "@shopify/react-native-skia": "2.2.12",
    "@testing-library/react-native": "^12.8.4",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "react-native-gesture-handler": "2.28.0",
    "react-native-reanimated": "4.1.3",
    "react-native-worklets": "0.5.1",
    "react-native-builder-bob": "^0.41.0"
  },
  "module": "./lib/module/index.js",
  "source": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mathnotes-app/mobile-ink.git"
  },
  "bugs": {
    "url": "https://github.com/mathnotes-app/mobile-ink/issues"
  },
  "homepage": "https://github.com/mathnotes-app/mobile-ink#readme",
  "keywords": [
    "react-native",
    "ink",
    "drawing",
    "canvas",
    "skia",
    "metal",
    "apple-pencil",
    "infinite-canvas",
    "notebook"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "react-native": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./src/index.ts"
      },
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json",
    "./native-ink-canvas": {
      "react-native": {
        "types": "./lib/typescript/module/NativeInkCanvas.d.ts",
        "default": "./src/NativeInkCanvas.tsx"
      },
      "import": {
        "types": "./lib/typescript/module/NativeInkCanvas.d.ts",
        "default": "./lib/module/NativeInkCanvas.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/NativeInkCanvas.d.ts",
        "default": "./lib/commonjs/NativeInkCanvas.js"
      }
    },
    "./continuous-engine-pool": {
      "react-native": {
        "types": "./lib/typescript/module/ContinuousEnginePool.d.ts",
        "default": "./src/ContinuousEnginePool.tsx"
      },
      "import": {
        "types": "./lib/typescript/module/ContinuousEnginePool.d.ts",
        "default": "./lib/module/ContinuousEnginePool.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/ContinuousEnginePool.d.ts",
        "default": "./lib/commonjs/ContinuousEnginePool.js"
      }
    },
    "./native-page-background": {
      "react-native": {
        "types": "./lib/typescript/module/NativeInkPageBackground.d.ts",
        "default": "./src/NativeInkPageBackground.tsx"
      },
      "import": {
        "types": "./lib/typescript/module/NativeInkPageBackground.d.ts",
        "default": "./lib/module/NativeInkPageBackground.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/NativeInkPageBackground.d.ts",
        "default": "./lib/commonjs/NativeInkPageBackground.js"
      }
    },
    "./zoomable-ink-viewport": {
      "react-native": {
        "types": "./lib/typescript/module/ZoomableInkViewport.d.ts",
        "default": "./src/ZoomableInkViewport.tsx"
      },
      "import": {
        "types": "./lib/typescript/module/ZoomableInkViewport.d.ts",
        "default": "./lib/module/ZoomableInkViewport.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/ZoomableInkViewport.d.ts",
        "default": "./lib/commonjs/ZoomableInkViewport.js"
      }
    },
    "./infinite-ink-canvas": {
      "react-native": {
        "types": "./lib/typescript/module/InfiniteInkCanvas.d.ts",
        "default": "./src/InfiniteInkCanvas.tsx"
      },
      "import": {
        "types": "./lib/typescript/module/InfiniteInkCanvas.d.ts",
        "default": "./lib/module/InfiniteInkCanvas.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/InfiniteInkCanvas.d.ts",
        "default": "./lib/commonjs/InfiniteInkCanvas.js"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
